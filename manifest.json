{
  "manifest_version": 3,
  "name": "NotesJet Manager Extension",
  "version": "1.0",
  "description": "An elegant extension to organize notes in notebooks",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "48": "icons/icon.png"
    }
  },
  "icons": {
    "48": "icons/icon.png"
  }
}
